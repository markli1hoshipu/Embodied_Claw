# Copy to .env (gitignored) and fill in real values. See bridge/README.md for setup.
SLACK_BOT_TOKEN=xoxb-REPLACE-ME
SLACK_APP_TOKEN=xapp-REPLACE-ME
SLACK_REQUESTS_CHANNEL_ID=C00000REQ
SLACK_STATUS_CHANNEL_ID=C00000STA
# Optional overrides:
# BRIDGE_RUNS_ROOT=/work/markhsp/Embodied_Claw/runs
#   Shared runs/ mailbox root. The bridge resolves BRIDGE_RUNS_ROOT, then falls back to the
#   pipeline's EMBODIED_CLAW_RUNS, then <repo>/runs — overriding EMBODIED_CLAW_RUNS alone keeps
#   both sides on the same mailbox; set BRIDGE_RUNS_ROOT only to diverge on purpose. Both the
#   bridge and the CLI driver log/print the resolved path at startup.
# EMBODIED_CLAW_RUNS=/work/markhsp/Embodied_Claw/runs
# BRIDGE_DB_PATH=/work/markhsp/Embodied_Claw/bridge/threads.sqlite
# BRIDGE_LOG_LEVEL=INFO
SLACK_EVAL_CHANNEL_ID=C_eval_channel_id_here
